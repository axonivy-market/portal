buildImage = null

pipeline {
  agent { label 'linux' }

  options {
    buildDiscarder(logRotator(numToKeepStr: '30', artifactNumToKeepStr: '5'))
  }

  triggers {
    cron('0 0 * * *')
  }

  parameters {
    string(name: 'portalBranch', defaultValue: 'master', description: 'Which branch of portal to test and build snapshot from?')
    string(name: 'engineDownloadURL', defaultValue: '-Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip', description: '''Where to download engine? e.g.
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip for nightly master
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/dev/axonivy-engine.zip for dev master
    ''')
    booleanParam(name: 'deployToRepo', defaultValue: true, description: 'Should deploy artifacts to repo? If true, deployable modules are deployed to Nexus snapshots. If false, only local install.')
}

  environment {
    engineDir = "${env.WORKSPACE}/engine"
  }

  stages {
    stage('Build Image') {
      steps {
        script {
          buildImage = docker.build('build-portal-snapshot', '-f build/create-release-snapshot/Dockerfile .')
        }
      }
    }

    stage('Checkout') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.portalBranch}"]],
          userRemoteConfigs: [[url: 'https://github.com/axonivy-market/portal.git']]
        ])
      }
    }

    stage('Build Documentation') {
      steps {
        script {
          withBuildImage {
            withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
              echo "Triggering documentation workflow on branch ${params.portalBranch}..."
              def dispatchResponse = sh(script: """gh api repos/axonivy-market/portal/actions/workflows/portal-documentation.yml/dispatches \
                -X POST \
                -f ref='${params.portalBranch}' \
                -f 'inputs[deploySnapshot]=${params.deployToRepo}' \
                -F return_run_details=true""", returnStdout: true).trim()
              def dispatchData = readJSON text: dispatchResponse
              def docWorkflowRunId = dispatchData.workflow_run_id
              echo "Documentation workflow triggered. Run ID: ${docWorkflowRunId}"

              sleep(time: 3, unit: 'MINUTES')
              def completed = false
              for (int i = 0; i < 6; i++) {
                def runJson = sh(
                  script: "gh api 'repos/axonivy-market/portal/actions/runs/${docWorkflowRunId}'",
                  returnStdout: true
                ).trim()
                def run = readJSON text: runJson
                echo "Documentation build #${run.run_number} status: ${run.status} - ${run.html_url}"
                if (run.status == 'completed') {
                  if (run.conclusion != 'success') {
                    error("Documentation build #${run.run_number} did not succeed. Conclusion was: ${run.conclusion}")
                  }
                  echo "✅ Documentation build #${run.run_number} was successful."
                  completed = true
                  break
                }
                sleep(time: 30, unit: 'SECONDS')
              }
              if (!completed) {
                error("Documentation workflow did not complete within the timeout period.")
              }
            }
          }
        }
      }
    }

    stage('deploy snapshot') {
      steps {
        script {
          withBuildImage {
            def mavenGoal = params.deployToRepo ? 'deploy' : 'install'
            maven cmd: "clean ${mavenGoal} -Prelease -f pom.xml -pl '!AxonIvyPortal/portal-selenium-test' -Divy.engine.directory=${env.engineDir} -Divy.engine.version=[7.0.0,] -Divy.compiler.engine.start.timeout=120 ${params.engineDownloadURL}"
          }
        }
      }
    }
  }

  post {
    always {
      script {
        if (currentBuild.currentResult == 'SUCCESS') {
          archiveArtifacts artifacts: '**/target/*.iar,AxonIvyPortal/PortalApp/target/*.zip,Showcase/portal-demo-app/target/*.zip,*/*/pom.xml', allowEmptyArchive: true
        }
      }
    }
  }
}

def withBuildImage(Closure body) {
  buildImage.inside('-v /var/tools/maven-cache:/home/build/') {
    body()
  }
}
