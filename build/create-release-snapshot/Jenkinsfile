def latestSha = ''
def seleniumTestPattern = 'com.axonivy.portal.selenium.test.**.*Test'
def buildImage

pipeline {
  agent { label 'linux' }

  options {
    buildDiscarder(logRotator(numToKeepStr: '30', artifactNumToKeepStr: '5'))
  }

  triggers {
    cron('0 14 * * *')
  }

  parameters {
    string(name: 'portalBranch', defaultValue: 'master', description: 'Which branch of portal to test and build snapshot from?')
    string(name: 'engineDownloadURL', defaultValue: '-Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip', description: '''Where to download engine? e.g.
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip for nightly master
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/dev/axonivy-engine.zip for dev master
    ''')
    booleanParam(name: 'deployToRepo', defaultValue: false, description: 'Should deploy artifacts to repo? If true, deployable modules are deployed to Nexus snapshots. If false, only local install.')
    booleanParam(name: 'skipVerification', defaultValue: false, description: 'Skip all verification stages and proceed directly to build and deploy.')
  }

  environment {
    engineDir = "${env.WORKSPACE}/engine"
  }

  stages {
    stage('Build Image') {
      steps {
        script {
          buildImage = docker.build('build-portal-snapshot', '-f build/create-release-snapshot/Dockerfile .')
        }
      }
    }

    stage('Checkout') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.portalBranch}"]],
          userRemoteConfigs: [[url: 'https://github.com/axonivy-market/portal.git']]
        ])
      }
    }

    stage('Verify Selenium Test') {
      when {
        expression { return !params.skipVerification }
      }
      steps {
        script {
          currentBuild.description = "On ${env.NODE_NAME}"
          withBuildImage {
            withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
              latestSha = sh(script: "gh api repos/axonivy-market/portal/commits/${params.portalBranch} --jq '.sha'", returnStdout: true).trim()
              echo "Latest ${params.portalBranch} SHA: ${latestSha}"
            }

            def portalBranchEncoded = URLEncoder.encode(params.portalBranch, 'UTF-8').replace('+', '%20')

            withCredentials([usernameColonPassword(credentialsId: 'wawa-jenkins', variable: 'credentials')]) {
              // Fetch the 10 most recent builds
              echo "Fetching selenium test builds from Jenkins API..."
              def buildsJson = sh(
                script: "curl -gsS --user \${credentials} '${env.JENKINS_URL}job/portal-selenium-test/job/${portalBranchEncoded}/api/json?tree=builds%5Bnumber%2Cresult%2Cactions%5B_class%2Ccauses%5B_class%5D%2ClastBuiltRevision%5BSHA1%5D%2Cparameters%5Bname%2Cvalue%5D%5D%5D%7B0%2C10%7D' || true",
                returnStdout: true
              ).trim()

              if (!buildsJson) {
                error("Failed to fetch selenium test builds.")
              }

              // Parse JSON and filter by SHA and testPatternToRun parameter
              def buildsData = readJSON text: buildsJson

              def shaMatchingBuilds = buildsData.builds.findAll { build ->
                def shaMatches = build.actions?.any { it._class == 'hudson.plugins.git.util.BuildData' && it.lastBuiltRevision?.SHA1 == latestSha }
                def buildPattern = build.actions?.find { it._class == 'hudson.model.ParametersAction' }?.parameters?.find { it.name == 'testPatternToRun' }?.value
                shaMatches && buildPattern == seleniumTestPattern
              }

              if (!shaMatchingBuilds) {
                error("No selenium test builds found matching SHA ${latestSha} and test pattern '${seleniumTestPattern}'.")
              }

              def matchedBuild = shaMatchingBuilds[0]
              echo "Found matching build #${matchedBuild.number} with result: ${matchedBuild.result}"

              if (matchedBuild.result != 'SUCCESS') {
                error("portal-selenium-test build #${matchedBuild.number} did not succeed. Result was: ${matchedBuild.result}")
              } else {
                echo "✅ portal-selenium-test build #${matchedBuild.number} was successful."
              }
            }
          }
        }
      }
    }

    stage('Verify Screenshot') {
      when {
        expression { return !params.skipVerification }
      }
      steps {
        script {
          withBuildImage {
            verifyGitHubWorkflow('portal-document-screenshot-test.yml', 'Screenshot')
          }
        }
      }
    }

    stage('Verify Documentation') {
      when {
        expression { return !params.skipVerification }
      }
      steps {
        script {
          withBuildImage {
            verifyGitHubWorkflow('portal-documentation.yml', 'Documentation')
          }
        }
      }
    }

    stage('Build Documentation') {
      steps {
        script {
          withBuildImage {
            withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
              echo "Triggering documentation workflow on branch ${params.portalBranch}..."
              def docDispatchTime = sh(script: "date -u +%Y-%m-%dT%H:%M:%SZ", returnStdout: true).trim()
              sh(script: """gh api repos/axonivy-market/portal/actions/workflows/portal-documentation.yml/dispatches \
                -X POST \
                -f ref='${params.portalBranch}' \
                -f 'inputs[deploySnapshot]=${params.deployToRepo}'""")
              echo "Documentation workflow dispatched at ${docDispatchTime}. Polling for completion..."

              sleep(time: 3, unit: 'MINUTES')
              def docRunId = null
              for (int i = 0; i < 6; i++) {
                def runsJson = sh(
                  script: "gh api 'repos/axonivy-market/portal/actions/workflows/portal-documentation.yml/runs?per_page=20&branch=${params.portalBranch}' --jq '.workflow_runs'",
                  returnStdout: true
                ).trim()
                def runs = readJSON text: runsJson
                def matchedRun = runs.find { run -> run.created_at >= docDispatchTime && run.status == 'completed' }
                if (matchedRun) {
                  docRunId = matchedRun.id
                  if (matchedRun.conclusion != 'success') {
                    error("Documentation workflow run ID ${docRunId} did not succeed. Conclusion was: ${matchedRun.conclusion}")
                  }
                  echo "✅ Documentation workflow run ID ${docRunId} was successful."
                  break
                }
                def inProgressRun = runs.find { run -> run.created_at > docDispatchTime }
                echo inProgressRun ? "Documentation run ID ${inProgressRun.id} in progress (status: ${inProgressRun.status}). Waiting..." : "No documentation run found yet. Waiting..."
                sleep(time: 30, unit: 'SECONDS')
              }
              if (!docRunId) {
                error("Documentation workflow did not complete within the timeout period.")
              }
            }
          }
        }
      }
    }

    stage('deploy snapshot') {
      steps {
        script {
          withBuildImage {
            // module structure [module path, isPossibleToDeploy]
            def modules = [['AxonIvyPortal/portal-components', true], ['AxonIvyPortal/portal', true], ['AxonIvyPortal/PortalKitTestHelper', false], ['Showcase/portal-user-examples', true], ['Showcase/portal-developer-examples', true], ['Showcase/InternalSupport', false], ['Showcase/portal-components-examples', true], ['AxonIvyPortal/portal-product', true], ['AxonIvyPortal/PortalApp', true], ['Showcase/portal-demo-app', true]]
            for (module in modules) {
              def mavenGoal = params.deployToRepo && module[1] ? 'deploy' : 'install'
              maven cmd: "clean ${mavenGoal} -Divy.engine.directory=${env.engineDir} -Divy.engine.version=[7.0.0,] -Divy.compiler.engine.start.timeout=120 ${params.engineDownloadURL} -f ${module[0]}/pom.xml"
            }
          }
        }
      }
    }
  }

  post {
    always {
      script {
        if (currentBuild.currentResult == 'SUCCESS') {
          archiveArtifacts artifacts: '**/target/*.iar,AxonIvyPortal/PortalApp/target/*.zip,Showcase/portal-demo-app/target/*.zip,*/*/pom.xml', allowEmptyArchive: true
        }
      }
    }
  }
}

def withBuildImage(Closure body) {
  buildImage.inside('-v /var/tools/maven-cache:/home/build/') {
    body()
  }
}

def verifyGitHubWorkflow(String workflowFile, String displayName) {
  withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
    echo "Fetching ${displayName} builds from GitHub Actions..."
    def json = sh(
      script: "gh api 'repos/axonivy-market/portal/actions/workflows/${workflowFile}/runs?per_page=10&branch=${params.portalBranch}' --jq '.workflow_runs'",
      returnStdout: true
    ).trim()

    if (!json) {
      error("Failed to fetch ${displayName} workflow runs.")
    }

    def runs = readJSON text: json
    def shaMatchingRuns = runs.findAll { run -> run.head_sha == latestSha && run.status == 'completed' }

    if (!shaMatchingRuns) {
      error("No ${displayName} builds found matching SHA ${latestSha}.")
    }

    def matchedRun = shaMatchingRuns[0]
    echo "${displayName} workflow run: ID ${matchedRun.id}, Status: ${matchedRun.status}, Conclusion: ${matchedRun.conclusion}"

    if (matchedRun.conclusion != 'success') {
      error("${displayName} workflow run ID ${matchedRun.id} did not succeed. Conclusion was: ${matchedRun.conclusion}")
    }
    echo "✅ ${displayName} workflow run ID ${matchedRun.id} was successful."
  }
}
