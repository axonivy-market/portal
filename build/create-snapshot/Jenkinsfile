pipeline {
  agent { label 'linux' }

  options {
    buildDiscarder(logRotator(numToKeepStr: '30', artifactNumToKeepStr: '5'))
  }

  triggers {
    cron('0 0 * * *')
  }

  parameters {
    string(name: 'releaseVersion', defaultValue: '', description: 'The snapshot version. If empty, auto-generated from the pom base version + timestamp + build number (e.g. 14.0.0-20260130.103918-1).')
    string(name: 'engineDownloadURL', defaultValue: '-Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip', description: '''Where to download engine? e.g.
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip for nightly master
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/dev/axonivy-engine.zip for dev master
    ''')
    booleanParam(name: 'deployToRepo', defaultValue: false, description: 'Should deploy artifacts to repo? If true, deployable modules are deployed to Nexus snapshots. If false, only local install.')
  }

  environment {
    engineDir = "$env.WORKSPACE/engine"
  }

  stages {
        stage('Verify Selenium Tests') {
      steps {
        script {
          currentBuild.description = "On ${env.NODE_NAME}"

          withCredentials([usernameColonPassword(credentialsId: 'wawa-jenkins', variable: 'credentials')]) {
            // Fetch the 10 most recent builds
            echo "Fetching selenium test builds from Jenkins API..."
            def buildsJson = sh(
              script: "curl -gsS --user \${credentials} '${env.JENKINS_URL}job/portal-selenium-test/job/master/api/json?tree=builds%5Bnumber,result,actions%5Bcauses%5B_class%5D%5D%5D%7B0,10%7D' || true",
              returnStdout: true
            ).trim()

            if (!buildsJson) {
              echo("❌ Failed to fetch selenium test builds.")
            }

            // Parse JSON and filter for timer trigger
            def buildsData = new groovy.json.JsonSlurper().parseText(buildsJson)

            def timerBuild = buildsData.builds.find { build ->
              build.actions?.any { action ->
                action.causes?.any { cause ->
                  cause._class == 'hudson.triggers.TimerTrigger$TimerTriggerCause'
                }
              }
            }

            echo "Timer build found: ${timerBuild != null}"

            // Check status and halt if failed (skips remaining stages)
            if (!timerBuild) {
              echo("❌ No timer-triggered build found among the last 10 builds of portal-selenium-test.")
            } else {
              echo "Found timer-triggered build #${timerBuild.number} with result: ${timerBuild.result}"
              
              if (timerBuild.result != 'SUCCESS') {
                echo("❌ Verification failed: portal-selenium-test build #${timerBuild.number} did not succeed. Result was: ${timerBuild.result}")
              } else {
                echo "✅ portal-selenium-test build #${timerBuild.number} was successful."
              }
            }
          }
        }
      }
    }

    stage('Verify Performance') {
      steps {
        script {
          withCredentials([usernameColonPassword(credentialsId: 'wawa-jenkins', variable: 'credentials')]) {
            sh "curl -s --user \${credentials} '${env.JENKINS_URL}job/portal-performance/job/release%2F12.0/lastCompletedBuild/api/json?tree=result' | grep -q '\"SUCCESS\"'"
          }
          echo "✅ portal-performance-test was successful."
        }
      }
    }

    stage('deploy snapshot') {
      steps {
        script {
          // Resolve effective version: use param if set, otherwise auto-generate
          def effectiveVersion = params.releaseVersion?.trim()
          if (!effectiveVersion) {
            def baseVersion = sh(
              script: "xmlstarlet sel -N n='http://maven.apache.org/POM/4.0.0' -t -v '/n:project/n:version' AxonIvyPortal/portal/pom.xml | sed 's/-SNAPSHOT//'",
              returnStdout: true
            ).trim()
            def timestamp = sh(script: 'date +%Y%m%d.%H%M%S', returnStdout: true).trim()
            effectiveVersion = "${baseVersion}-${timestamp}-${env.BUILD_NUMBER}"
          }
          echo "Building snapshot with version: ${effectiveVersion}"
          currentBuild.description = "${effectiveVersion} on ${env.NODE_NAME}"

          docker.build('build-portal-snapshot', '-f build/Dockerfile .').inside('-v /var/tools/maven-cache:/home/build/') {
            updateVersion(effectiveVersion)

            // module structure [module path, isPossibleToDeploy]
            def modules = [['AxonIvyPortal/portal-components', true], ['AxonIvyPortal/portal', true], ['AxonIvyPortal/PortalKitTestHelper', false], ['Showcase/portal-user-examples', true], ['Showcase/portal-developer-examples', true], ['Showcase/InternalSupport', false], ['Showcase/portal-components-examples', true], ['AxonIvyPortal/portal-product', true], ['AxonIvyPortal/PortalApp', true], ['Showcase/portal-demo-app', true]]
            for (module in modules) {
              def mavenGoal = params.deployToRepo && module[1] ? 'deploy' : 'install'
              maven cmd: "clean ${mavenGoal} -Divy.engine.directory=${env.engineDir} -Divy.engine.version=[7.0.0,] -Divy.compiler.engine.start.timeout=120 ${params.engineDownloadURL} -f ${module[0]}/pom.xml"
            }
          }
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: '**/target/*.iar,AxonIvyPortal/PortalApp/target/*.zip,Showcase/portal-demo-app/target/*.zip,*/*/pom.xml', allowEmptyArchive: true
    }
  }
}

def updateVersion(def releaseVersion) {
  def POM_PATTERN_FILES = [
    'AxonIvyPortal/*/pom.xml',
    'Showcase/*/pom.xml',
    'AxonIvyPortal/portal-selenium-test/customized_pom.xml',
    'AxonIvyPortal/portal-selenium-test/document_screenshot_pom.xml',
    'Documentation/public-api/pom.xml'
  ]

  def DEPENDENCY_GROUP_IDS = [
    'ch.ivyteam.ivy.project.portal',
    'com.axonivy.portal'
  ]

  def pomFiles = []
  POM_PATTERN_FILES.each { pattern ->
    def foundFiles = sh(script: "find ${pattern}", returnStdout: true).trim().split('\n')
    pomFiles.addAll(foundFiles)
  }

  pomFiles.each { pomFile ->
    sh """
       xmlstarlet ed --inplace \
       -N n="http://maven.apache.org/POM/4.0.0" \
       -u "/n:project/n:version" -v "${releaseVersion}" ${pomFile}
       """
    for (groupId in DEPENDENCY_GROUP_IDS) {
      sh """
         xmlstarlet ed --inplace \
         -N n="http://maven.apache.org/POM/4.0.0" \
         -u "//n:dependencies/n:dependency[n:groupId='${groupId}']/n:version" \
         -v "${releaseVersion}" ${pomFile}
         """
    }
  }
}