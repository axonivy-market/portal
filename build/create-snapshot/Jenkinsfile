def canContinue = true
def latestSha = ''
def seleniumTestPattern = 'com.axonivy.portal.selenium.test.**.*Test'
def buildImage
pipeline {
  agent { label 'linux' }

  options {
    buildDiscarder(logRotator(numToKeepStr: '30', artifactNumToKeepStr: '5'))
  }

  triggers {
    cron('0 14 * * *')
  }

  parameters {
    string(name: 'portalBranch', defaultValue: 'master', description: 'Which branch of portal to test and build snapshot from?')
    string(name: 'engineDownloadURL', defaultValue: '-Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip', description: '''Where to download engine? e.g.
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip for nightly master
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/dev/axonivy-engine.zip for dev master
    ''')
    booleanParam(name: 'deployToRepo', defaultValue: false, description: 'Should deploy artifacts to repo? If true, deployable modules are deployed to Nexus snapshots. If false, only local install.')
    booleanParam(name: 'skipVerification', defaultValue: false, description: 'Skip the Verify Selenium Test and Verify Performance stages and proceed directly to deploy.')
  }

  environment {
    engineDir = "$env.WORKSPACE/engine"
  }

  stages {
    stage('Build Image') {
      steps {
        script {
          buildImage = docker.build('build-portal-snapshot', '-f build/create-snapshot/Dockerfile .')
        }
      }
    }

    stage('Verify Selenium Test') {
      when {
        expression { return !params.skipVerification }
      }
      steps {
        script {
          currentBuild.description = "On ${env.NODE_NAME}"
          buildImage.inside('-v /var/tools/maven-cache:/home/build/') {
            withCredentials([string(credentialsId: 'lmluat-gh-token', variable: 'GH_TOKEN')]) {
              latestSha = sh(script: "gh api repos/axonivy-market/portal/commits/${params.portalBranch} --jq '.sha'", returnStdout: true).trim()
              echo "Latest ${params.portalBranch} SHA: ${latestSha}"
            }

            def portalBranchEncoded = URLEncoder.encode(params.portalBranch, 'UTF-8').replace('+', '%20')

            withCredentials([usernameColonPassword(credentialsId: 'wawa-jenkins', variable: 'credentials')]) {
              // Fetch the 10 most recent builds
              echo "Fetching selenium test builds from Jenkins API..."
              def buildsJson = sh(
                script: "curl -gsS --user \${credentials} '${env.JENKINS_URL}job/portal-selenium-test/job/${portalBranchEncoded}/api/json?tree=builds%5Bnumber%2Cresult%2Cactions%5B_class%2Ccauses%5B_class%5D%2ClastBuiltRevision%5BSHA1%5D%2Cparameters%5Bname%2Cvalue%5D%5D%5D%7B0%2C10%7D' || true",
                returnStdout: true
              ).trim()

              if (!buildsJson) {
                canContinue = false
                echo("❌ Failed to fetch selenium test builds.")
                error("Failed to fetch selenium test builds.")
              }

              // Parse JSON and filter by SHA and testPatternToRun parameter
              def buildsData = new groovy.json.JsonSlurper().parseText(buildsJson)

              def shaMatchingBuilds = buildsData.builds.findAll { build ->
                def shaMatches = build.actions?.any { it._class == 'hudson.plugins.git.util.BuildData' && it.lastBuiltRevision?.SHA1 == latestSha }
                def buildPattern = build.actions?.find { it._class == 'hudson.model.ParametersAction' }?.parameters?.find { it.name == 'testPatternToRun' }?.value
                shaMatches && buildPattern == seleniumTestPattern
              }

              if (!shaMatchingBuilds) {
                canContinue = false
                echo("❌ No selenium test builds found matching SHA ${latestSha} and test pattern '${seleniumTestPattern}'.")
                error("No selenium test builds found matching SHA and test pattern.")
              }

              def matchedBuild = shaMatchingBuilds[0]
              echo "Found matching build #${matchedBuild.number} with result: ${matchedBuild.result}"

              if (matchedBuild.result != 'SUCCESS') {
                canContinue = false
                echo("❌ Verification failed: portal-selenium-test build #${matchedBuild.number} did not succeed. Result was: ${matchedBuild.result}")
                error("portal-selenium-test build #${matchedBuild.number} did not succeed. Result was: ${matchedBuild.result}")
              } else {
                echo "✅ portal-selenium-test build #${matchedBuild.number} was successful."
              }
            }
          }
        }
      }
    }

    stage('Verify Screenshot') {
      when {
        expression { return canContinue && !params.skipVerification }
      }
      steps {
        script {
          buildImage.inside('-v /var/tools/maven-cache:/home/build/') {
            withCredentials([string(credentialsId: 'lmluat-gh-token', variable: 'GH_TOKEN')]) {
              echo "Fetching screenshot builds from GitHub Actions..."
              def screenshotJson = sh(
                script: "gh api 'repos/axonivy-market/portal/actions/workflows/portal-document-screenshot-test.yml/runs?per_page=50&branch=${params.portalBranch}' --jq '.workflow_runs'",
                returnStdout: true
              ).trim()

              if (!screenshotJson) {
                canContinue = false
                echo("❌ Failed to fetch screenshot workflow runs.")
                error("Failed to fetch screenshot workflow runs.")
              }

              def screenshotRuns = new groovy.json.JsonSlurper().parseText(screenshotJson)

              def shaMatchingRuns = screenshotRuns.findAll { run ->
                run.head_sha == latestSha
              }

              if (!shaMatchingRuns) {
                canContinue = false
                echo("❌ No screenshot builds found matching SHA ${latestSha} '.")
                error("No screenshot builds found matching SHA ${latestSha} '.")
              }

              def screenshotRun = shaMatchingRuns[0]
              echo "Screenshot workflow run: ID ${screenshotRun.id}, Status: ${screenshotRun.status}, Conclusion: ${screenshotRun.conclusion}"

              if (screenshotRun.conclusion != 'success') {
                canContinue = false
                echo("❌ Verification failed: screenshot workflow run ID ${screenshotRun.id} did not succeed. Conclusion was: ${screenshotRun.conclusion}")
                error("Screenshot workflow run ID ${screenshotRun.id} did not succeed. Conclusion was: ${screenshotRun.conclusion}")
              } else {
                echo "✅ Screenshot workflow run ID ${screenshotRun.id} was successful."
              }
            }
          }
        }
      }
    }

    stage('Verify Documentation') {
      when {
        expression { return canContinue && !params.skipVerification }
      }
      steps {
        script {
          buildImage.inside('-v /var/tools/maven-cache:/home/build/') {
            withCredentials([string(credentialsId: 'lmluat-gh-token', variable: 'GH_TOKEN')]) {
              echo "Fetching documentation builds from GitHub Actions..."
              def docJson = sh(
                script: "gh api 'repos/axonivy-market/portal/actions/workflows/portal-documentation.yml/runs?per_page=50&branch=${params.portalBranch}' --jq '.workflow_runs'",
                returnStdout: true
              ).trim()

              if (!docJson) {
                canContinue = false
                echo("❌ Failed to fetch documentation workflow runs.")
                error("Failed to fetch documentation workflow runs.")
              }

              def docRuns = new groovy.json.JsonSlurper().parseText(docJson)

              def shaMatchingDocRuns = docRuns.findAll { run ->
                run.head_sha == latestSha && run.status == 'completed'
              }

              if (!shaMatchingDocRuns) {
                canContinue = false
                echo("❌ No documentation builds found matching SHA ${latestSha}.")
                error("No documentation builds found matching SHA ${latestSha}.")
              }

              def docRun = shaMatchingDocRuns[0]
              echo "Documentation workflow run: ID ${docRun.id}, Status: ${docRun.status}, Conclusion: ${docRun.conclusion}"

              if (docRun.conclusion != 'success') {
                canContinue = false
                echo("❌ Verification failed: documentation workflow run ID ${docRun.id} did not succeed. Conclusion was: ${docRun.conclusion}")
                error("Documentation workflow run ID ${docRun.id} did not succeed. Conclusion was: ${docRun.conclusion}")
              } else {
                echo "✅ Documentation workflow run ID ${docRun.id} was successful."
              }
            }
          }
        }
      }
    }

    stage('deploy snapshot') {
      when {
        expression { return canContinue }
      }
      steps {
        script {
          buildImage.inside('-v /var/tools/maven-cache:/home/build/') {
            // module structure [module path, isPossibleToDeploy]
            def modules = [['AxonIvyPortal/portal-components', true], ['AxonIvyPortal/portal', true], ['AxonIvyPortal/PortalKitTestHelper', false], ['Showcase/portal-user-examples', true], ['Showcase/portal-developer-examples', true], ['Showcase/InternalSupport', false], ['Showcase/portal-components-examples', true], ['AxonIvyPortal/portal-product', true], ['AxonIvyPortal/PortalApp', true], ['Showcase/portal-demo-app', true]]
            for (module in modules) {
              def mavenGoal = params.deployToRepo && module[1] ? 'deploy' : 'install'
              maven cmd: "clean ${mavenGoal} -Divy.engine.directory=${env.engineDir} -Divy.engine.version=[7.0.0,] -Divy.compiler.engine.start.timeout=120 ${params.engineDownloadURL} -f ${module[0]}/pom.xml"
            }
          }
        }
      }
    }
  }

  post {
    always {
      script {
        if (canContinue) {
          archiveArtifacts artifacts: '**/target/*.iar,AxonIvyPortal/PortalApp/target/*.zip,Showcase/portal-demo-app/target/*.zip,*/*/pom.xml', allowEmptyArchive: true
        }
      }
    }
  }
}
