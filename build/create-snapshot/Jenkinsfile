def canContinue = true
def latestSha = ''
def fullTestPattern = 'com.axonivy.portal.selenium.test.**.*Test'
pipeline {
  agent { label 'linux' }

  options {
    buildDiscarder(logRotator(numToKeepStr: '30', artifactNumToKeepStr: '5'))
  }

  triggers {
    cron('0 14 * * *')
  }

  parameters {
    string(name: 'engineDownloadURL', defaultValue: '-Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip', description: '''Where to download engine? e.g.
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/nightly/axonivy-engine.zip for nightly master
      -Divy.engine.download.url=https://developer.axonivy.com/permalink/dev/axonivy-engine.zip for dev master
    ''')
    booleanParam(name: 'deployToRepo', defaultValue: false, description: 'Should deploy artifacts to repo? If true, deployable modules are deployed to Nexus snapshots. If false, only local install.')
    booleanParam(name: 'skipVerification', defaultValue: false, description: 'Skip the Verify Selenium Test and Verify Performance stages and proceed directly to deploy.')
  }

  environment {
    engineDir = "$env.WORKSPACE/engine"
  }

  stages {
    stage('Verify Selenium Test') {
      when {
        expression { return !params.skipVerification }
      }
      steps {
        script {
          currentBuild.description = "On ${env.NODE_NAME}"

          latestSha = sh(script: "gh api repos/:owner/:repo/git/refs/heads/master --jq '.object.sha'", returnStdout: true).trim()
          echo "Latest master SHA: ${latestSha}"

          withCredentials([usernameColonPassword(credentialsId: 'wawa-jenkins', variable: 'credentials')]) {
            // Fetch the 10 most recent builds
            echo "Fetching selenium test builds from Jenkins API..."
            def buildsJson = sh(
              script: "curl -gsS --user \${credentials} '${env.JENKINS_URL}job/portal-selenium-test/job/master/api/json?tree=builds%5Bnumber%2Cresult%2Cactions%5B_class%2Ccauses%5B_class%5D%2ClastBuiltRevision%5BSHA1%5D%2Cparameters%5Bname%2Cvalue%5D%5D%5D%7B0%2C10%7D' || true",
              returnStdout: true
            ).trim()

            if (!buildsJson) {
              echo("❌ Failed to fetch selenium test builds.")
              canContinue = false
              currentBuild.result = 'FAILURE'
              return
            }

            // Parse JSON and filter by SHA and testPatternToRun parameter
            def buildsData = new groovy.json.JsonSlurper().parseText(buildsJson)

            def shaMatchingBuilds = buildsData.builds.findAll { build ->
              def buildSha = build.actions?.find { it._class == 'hudson.plugins.git.util.BuildData' }?.lastBuiltRevision?.SHA1
              def buildPattern = build.actions?.find { it._class == 'hudson.model.ParametersAction' }?.parameters?.find { it.name == 'testPatternToRun' }?.value
              buildSha == latestSha && buildPattern == fullTestPattern
            }

            if (!shaMatchingBuilds) {
              echo("❌ No selenium test builds found matching SHA ${latestSha} and test pattern '${fullTestPattern}'.")
              canContinue = false
              currentBuild.result = 'FAILURE'
              return
            }

            // Among SHA-matching builds, find a timer-triggered one
            def timerBuild = shaMatchingBuilds.find { build ->
              build.actions?.any { action ->
                action.causes?.any { cause ->
                  cause._class == 'hudson.triggers.TimerTrigger$TimerTriggerCause'
                }
              }
            }

            echo "Timer build found: ${timerBuild != null}"

            // Check status and halt if failed (skips remaining stages)
            if (!timerBuild) {
              echo("❌ No timer-triggered build found among the last 10 builds of portal-selenium-test.")
              canContinue = false
              currentBuild.result = 'FAILURE'
            } else {
              echo "Found timer-triggered build #${timerBuild.number} with result: ${timerBuild.result}"

              if (timerBuild.result != 'SUCCESS') {
                echo("❌ Verification failed: portal-selenium-test build #${timerBuild.number} did not succeed. Result was: ${timerBuild.result}")
                canContinue = false
                currentBuild.result = 'FAILURE'
              } else {
                echo "✅ portal-selenium-test build #${timerBuild.number} was successful."
              }
            }
          }
        }
      }
    }

    stage('Verify Performance') {
      when {
        expression { return canContinue && !params.skipVerification }
      }
      steps {
        script {
          withCredentials([usernameColonPassword(credentialsId: 'wawa-jenkins', variable: 'credentials')]) {
            def perfJson = sh(
              script: "curl -gsS --user \${credentials} '${env.JENKINS_URL}job/portal-performance/job/master/api/json?tree=builds%5Bnumber%2Cresult%2Cactions%5B_class%2ClastBuiltRevision%5BSHA1%5D%5D%5D%7B0%2C10%7D' || true",
              returnStdout: true
            ).trim()

            if (!perfJson) {
              echo("❌ Failed to fetch performance test builds.")
              canContinue = false
              currentBuild.result = 'FAILURE'
              return
            }

            def perfBuildsData = new groovy.json.JsonSlurper().parseText(perfJson)

            def shaMatchingPerf = perfBuildsData.builds.findAll { build ->
              build.actions?.find { it._class == 'hudson.plugins.git.util.BuildData' }?.lastBuiltRevision?.SHA1 == latestSha
            }

            if (!shaMatchingPerf) {
              echo("❌ No performance builds found matching SHA ${latestSha}.")
              canContinue = false
              currentBuild.result = 'FAILURE'
              return
            }

            def perfBuild = shaMatchingPerf[0]
            echo "Performance build number: ${perfBuild.number}"
            echo "Portal Performance Test Status: ${perfBuild.result}"

            if (perfBuild.result != 'SUCCESS') {
              echo("❌ Verification failed: performance build #${perfBuild.number} did not succeed. Result was: ${perfBuild.result}")
              canContinue = false
              currentBuild.result = 'FAILURE'
            } else {
              echo "✅ portal-performance-test build #${perfBuild.number} was successful."
            }
          }
        }
      }
    }

    stage('deploy snapshot') {
      when {
        expression { return canContinue }
      }
      steps {
        script {
          docker.build('build-portal-snapshot', '-f build/Dockerfile .').inside('-v /var/tools/maven-cache:/home/build/') {
            // module structure [module path, isPossibleToDeploy]
            def modules = [['AxonIvyPortal/portal-components', true], ['AxonIvyPortal/portal', true], ['AxonIvyPortal/PortalKitTestHelper', false], ['Showcase/portal-user-examples', true], ['Showcase/portal-developer-examples', true], ['Showcase/InternalSupport', false], ['Showcase/portal-components-examples', true], ['AxonIvyPortal/portal-product', true], ['AxonIvyPortal/PortalApp', true], ['Showcase/portal-demo-app', true]]
            for (module in modules) {
              def mavenGoal = params.deployToRepo && module[1] ? 'deploy' : 'install'
              maven cmd: "clean ${mavenGoal} -Divy.engine.directory=${env.engineDir} -Divy.engine.version=[7.0.0,] -Divy.compiler.engine.start.timeout=120 ${params.engineDownloadURL} -f ${module[0]}/pom.xml"
            }
          }
        }
      }
    }
  }

  post {
    always {
      script {
        if (canContinue) {
          archiveArtifacts artifacts: '**/target/*.iar,AxonIvyPortal/PortalApp/target/*.zip,Showcase/portal-demo-app/target/*.zip,*/*/pom.xml', allowEmptyArchive: true
        }
      }
    }
  }
}
