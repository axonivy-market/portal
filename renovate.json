{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "baseBranchPatterns": [
        "master",
        "release/12.0",
        "release/10.0"
    ],
    "labels": [
        "skip-changelog"
    ],
    "timezone": "Asia/Bangkok",
    "schedule": ["before 5am on monday"],
    "rebaseWhen": "never",
    "semanticCommits": "disabled",
    "maven": {
        "fileMatch": [
            "(^|/|\\\\)pom\.xml$",
            "(^|/|\\\\)customized_pom\.xml$",
            "(^|/|\\\\)document_screenshot_pom\.xml$",
            "(^|/|\\\\)deployment-pom\.xml$"
        ]
    },
    "packageRules": [
        {
            "description": "Disable major upgrades for release branches",
            "matchBaseBranches": [
                "release/10.0",
                "release/12.0"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "dependencyDashboardApproval": true,
            "enabled": false
        }
    ]
}
