{
  "$schema" : "https://json-schema.axonivy.com/14.0-dev/project/process.json",
  "id" : "A1B2C3D4E5F60001",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "com.axonivy.portal.components.examples.equipmentrequest.AuditTrailAdditionalInformationData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "getAdditionalInformationInAuditTrail(Long)",
      "config" : {
        "signature" : "getAdditionalInformationInAuditTrail",
        "input" : {
          "params" : [
            { "name" : "businessCaseId", "type" : "Long", "desc" : "" }
          ],
          "map" : {
            "out.businessCaseId" : "param.businessCaseId"
          }
        },
        "result" : {
          "params" : [
            { "name" : "taskId", "type" : "Long", "desc" : "" },
            { "name" : "content", "type" : "String", "desc" : "" },
            { "name" : "status", "type" : "String", "desc" : "" }
          ],
          "map" : {
            "result.taskId" : "in.taskId",
            "result.content" : "in.content",
            "result.status" : "in.status"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f2", "to" : "f3" }
      ]
    }, {
      "id" : "f1",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 480, "y" : 64 }
      }
    }, {
      "id" : "f3",
      "type" : "Script",
      "name" : "get additional information",
      "config" : {
        "output" : {
          "map" : {
            "out" : "in",
            "out.businessCaseId" : "in.businessCaseId"
          },
          "code" : [
            "import ch.ivyteam.ivy.workflow.ICase;",
            "import ch.ivyteam.ivy.workflow.ITask;",
            "import com.axonivy.portal.components.enums.CustomProcessStatus;",
            "",
            "in.status = CustomProcessStatus.SKIP.name();",
            "if (in.businessCaseId == null || in.businessCaseId.isEmpty()) {",
            "  return;",
            "}",
            "ICase businessCase = ivy.wf.getCase(Long.parseLong(in.businessCaseId));",
            "if (businessCase == null) {",
            "  return;",
            "}",
            "for (ITask task : businessCase.tasks().all()) {",
            "  String rejectionReason = task.customFields().stringField(\"rejectionReason\").getOrNull();",
            "  if (rejectionReason != null && !rejectionReason.isEmpty()) {",
            "    in.taskId = task.getId();",
            "    in.content = rejectionReason;",
            "    in.status = CustomProcessStatus.OK.name();",
            "    break;",
            "  }",
            "}"
          ]
        },
        "sudo" : true
      },
      "visual" : {
        "at" : { "x" : 288, "y" : 64 }
      },
      "connect" : [
        { "id" : "f4", "to" : "f1" }
      ]
    } ]
}