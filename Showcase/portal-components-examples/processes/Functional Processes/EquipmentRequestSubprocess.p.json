      "type" : "CallSubStart",
      "name" : "portalGetAuditTrailDat(ICase)",
      "config" : {
        "signature" : "portalGetAuditTrailDat",
        "input" : {
          "params" : [
            { "name" : "businessCase", "type" : "ch.ivyteam.ivy.workflow.ICase", "desc" : "" }
          ],
          "map" : {
