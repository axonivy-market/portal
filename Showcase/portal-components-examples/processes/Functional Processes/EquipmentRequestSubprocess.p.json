    }, {
      "id" : "f14",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 624, "y" : 304 }
      }
    }, {
      "id" : "f16",
      "type" : "Script",
      "config" : {
        "output" : {
          "map" : {
            "out" : "in",
            "out.auditTrailDataForTaskUpdateRequest" : "in.auditTrailDataForTaskUpdateRequest"
          },
          "code" : [
            "import com.axonivy.portal.components.factory.AuditTrailDTOFactory;",
            "import com.axonivy.portal.components.dto.AuditTrailDTO;",
            "import ch.ivyteam.ivy.workflow.note.Note;",
            "import ch.ivyteam.ivy.workflow.ITask;",
            "import ch.ivyteam.ivy.workflow.category.Category;",
            "import java.util.ArrayList;",
            "",
            "List<ITask> activeTasks = in.businessCase.tasks().allActive();",
            "if (!activeTasks.isEmpty()) {",
            "  ITask targetTask = activeTasks.get(0);",
            "  Category taskCategory = targetTask.getCategory();",
            "  String value = taskCategory.getName().isBlank() ? \"\" : taskCategory.getName();",
            "  ivy.log.info(value.equals(\"updateRequest\"));",
            "  in.auditTrailDataForTaskUpdateRequest = new ArrayList();",
            "    if (value.equals(\"updateRequest\")) {",
            "      for(Note note : targetTask.notes().all()) {",
            "        AuditTrailDTO trail = AuditTrailDTOFactory.build(\"System note\", note.content());",
            "        in.auditTrailDataForTaskUpdateRequest.add(trail);",
            "      }",
            "    }",
            "}"
          ]
        },
        "sudo" : true
      },
      "visual" : {
        "at" : { "x" : 320, "y" : 304 }
      },
      "connect" : [
        { "id" : "f17", "to" : "f14", "color" : "default" }
