          },
          "code" : [
            "import java.util.ArrayList;",
            "import com.axonivy.portal.components.factory.AuditTrailDTOFactory;",
            "import com.axonivy.portal.components.dto.AuditTrailDTO;",
            "String content = ivy.session.getSessionUserName() + \" reserved the task\";",
            "in.workingTask.notes().add().content(content).execute();",
            "ivy.log.info(in.workingTask.notes().all());"
          ]
