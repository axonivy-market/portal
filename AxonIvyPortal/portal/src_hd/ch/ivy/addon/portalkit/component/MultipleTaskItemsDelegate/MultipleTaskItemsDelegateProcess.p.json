    }, {
      "id" : "f53",
      "type" : "Script",
      "config" : {
        "output" : {
          "map" : {
            "out" : "in",
            "out.numberOfSelectedTasks" : "in.numberOfSelectedTasks",
            "out.selectedTasks" : "in.selectedTasks"
          },
          "code" : [
            "import ch.ivy.addon.portalkit.util.TaskUtils;",
            "import ch.ivyteam.ivy.workflow.ITask;",
            "import ch.ivy.addon.portalkit.util.TaskUtils;",
            "import ch.ivy.addon.portalkit.util.SecurityMemberUtils;",
            "import org.apache.commons.lang3.StringUtils;",
            "ivy.log.info(in.numberOfSelectedTasks == -1);",
            "if (in.numberOfSelectedTasks > -1) {",
            "  in.targetTask = in.selectedTasks.get(in.numberOfSelectedTasks);",
            "  if (in.targetTask != null) {",
            "    TaskUtils.resetTask(in.targetTask);",
            "  }",
            "",
            "  String newResponsibleName = \"\";",
            "",
            "  if (in.#selectedUser != null) {",
            "    newResponsibleName = in.#selectedUser.#displayName;",
            "    in.delegatedSecurityMember = SecurityMemberUtils.findISecurityMemberFromUserDTO(in.selectedUser);",
            "  } else if (in.#selectedRole != null) {",
            "    newResponsibleName = in.#selectedRole.#displayName;",
            "    in.delegatedSecurityMember = SecurityMemberUtils.findISecurityMemberFromRoleDTO(in.selectedRole);",
            "  }",
            "",
            "  String oldResponsibleName = TaskUtils.toDisplayNameResponsible(in.targetTask.responsibles());",
            "  in.delegateComment = StringUtils.isBlank(in.#taskDelegationComment) ?",
            "    ivy.cms.co(\"/ch.ivy.addon.portalkit.ui.jsf/taskDelegate/delegateComment\", [in.targetTask.getId(), oldResponsibleName, newResponsibleName])",
            "    : ivy.cms.co(\"/ch.ivy.addon.portalkit.ui.jsf/taskDelegate/delegateReasonIncludedComment\", [in.targetTask.getId(), oldResponsibleName, newResponsibleName, in.#taskDelegationComment.trim()]);",
            "",
            "  in.taskDelegationComment = \"\";",
            "}"
          ]
        }
      },
